{
  "name": "box-dancer-vue",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy:cloudflare": "pnpm build && wrangler pages deploy dist --project-name box-dancer-vue",
    "deploy": "vite build && scp -r -P 2222 dist/* lolipop:~/web/amry/tools/box-dancer-vue"
  },
  "dependencies": {
    "sass": "^1.100.0",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@vicons/carbon": "^0.12.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "naive-ui": "^2.44.1",
    "typescript": "^6.0.3",
    "vfonts": "^0.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.3",
    "wrangler": "^4.98.0"
  }
}
